{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pathbranching",
  "mainBinaryName": "Pathbranching",
  "version": "0.2.0",
  "identifier": "studio.everendforge.pathbranching",
  "build": {
    "beforeDevCommand": "npm run dev -- --port 5174 --strictPort",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pathbranching",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$HOME/**/.everend/**"
        ]
      }
    }
  },
  "plugins": {
    "window-state": null
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
